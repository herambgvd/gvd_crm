# App
APP_NAME=GVD CRM API
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
MONGO_URL=mongodb://localhost:27017
DB_NAME=gvd_crm_db

# Security (REQUIRED - generate strong random values)
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET=change-me-to-a-random-jwt-secret
JWT_EXPIRATION_HOURS=8
JWT_REFRESH_EXPIRATION_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Base URL (frontend URL used in emails)
BASE_URL=http://localhost:3000

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=True

# External APIs (optional)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Logging
LOG_LEVEL=INFO

# Redis (optional)
REDIS_URL=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=300

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

# Monitoring (optional)
SENTRY_DSN=
